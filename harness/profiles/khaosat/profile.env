# profile.env — khaosat (Express ESM + Prisma + React/Vite). Driver nhận URL → dùng thẳng DATABASE_URL/REDIS_URL.
# Lưu ý: repo dev mặc định SQLite; lane chạy Postgres ⇒ schema.prisma cần provider="postgresql" (xem README repo app).
DB_URL_SCHEME="postgresql"
API_PATH="/api"
UPLOAD_SUBDIR="uploads"
BACKEND_DIR="."
FRONTEND_DIR="client"
DB_SERVICE="postgres"
COMPOSE_SERVICES="postgres redis adminer"
BASE_BRANCH="main"
INTEGRATION_BRANCH="development"
BRANCH_PREFIX="feat/"
TEST_PATHS="test/"

# --- App-specific (khaosat) ---
PKG_MGR="npm"
BUILD_SCRIPT="build"              # npm run build = vite build client → client/dist
START_CMD="node server/index.js"  # prod: Express :$PORT serve API + client/dist
SEED_SCRIPT="seed"                # node prisma/seed.js (nạp data/khao-sat-nq57.json)
LINT_SCRIPT="lint"
TEST_SCRIPT="test"                # vitest run
E2E_SCRIPT="test"                 # chưa có e2e riêng — tạm dùng bộ test API
MIGRATE_CMD="npx prisma migrate deploy"
HEALTH_PATH="/health"
